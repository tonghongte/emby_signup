# ==========================================
# Emby Signup 环境变量配置模版 (.env.example)
# ==========================================

# Emby 服务器配置
EMBY_BASE_URL=http://your-emby-ip:8096
EMBY_API_TOKEN=your_emby_api_token
EMBY_TEMPLATE_USER_ID=your_template_user_id

# 站点配置
SITE_LOGIN_URL=http://your-emby-ip:8096

# 管理员安全配置 (默认用户名 admin, 密码 password)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=password

# SMTP 邮件发送配置
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=ssl
SMTP_USERNAME=your_email@qq.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_NAME=Emby Admin

# TMDB 电影海报墙配置
TMDB_API_KEY=
TMDB_PROXY=
TMDB_LANGUAGE=zh-CN

# 系统自动化与通知开关
ENABLE_REQUEST_EMAIL_NOTIFY=false
ENABLE_AUTO_BAN=false
AUTO_BAN_DAYS=30
